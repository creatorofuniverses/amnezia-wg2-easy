# Copy to .env and fill in. Consumed by docker-compose.yml and
# docker-compose.proxy.yml.

# ── Core (required) ───────────────────────────────────────────────
# Your server's public IP or hostname (REQUIRED).
WG_HOST=
# Web UI admin password (leave empty to disable authentication).
PASSWORD=
# UI language code (e.g. en).
LANGUAGE=en
# Web UI port (tcp).
PORT=51821
# Client-facing VPN port (udp). In proxy mode the proxy listens here;
# clients dial WG_HOST:WG_PORT.
WG_PORT=51820

# ── Obfuscation proxy (only used by docker-compose.proxy.yml) ─────
# Protocol to imitate: quic | dns | stun | sip | auto
PROXY_PROTOCOL=quic
# Stateful QUIC/TLS responder (true = stronger obfuscation).
PROXY_QUIC_HANDSHAKE=true
# SNI domain for the QUIC handshake certificate.
PROXY_QUIC_DOMAIN=cloudflare.com
# Answer real DNS queries upstream. Requires PROXY_PROTOCOL=dns or auto —
# the proxy REFUSES TO START (and will crash-loop) if set true with another protocol.
PROXY_DNS_FORWARD=false
# Upstream resolver used when PROXY_DNS_FORWARD=true.
PROXY_DNS_UPSTREAM=1.1.1.1:53
